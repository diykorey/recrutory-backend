<configuration>
	<contextName>FrontEnd</contextName>
	<jmxConfigurator />
	<property resource="properties/common.properties" />

	<appender name="RF" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<param name="File" value="${logs.path}/frontend-logging.log" />
		<encoder>
			<charset>UTF-8</charset>
			<param name="Pattern" value="%date{HH:mm:ss.SSS} [%thread] %-10level [%file:%line] - %msg - %logger %date{dd:MM:yyyy}%n" />
		</encoder>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<param name="FileNamePattern" value="${logs.path}/bkp/frontend-logging-%d{yyyy-MM-dd_HH}.%i.log" />
			<timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
				<maxFileSize>300MB</maxFileSize>
			</timeBasedFileNamingAndTriggeringPolicy>
		</rollingPolicy>
	</appender>

	<appender name="HttpRequest" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${logs.path}/frontend-request.log</file>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<!-- daily rollover -->
			<fileNamePattern>${logs.path}/bkp/frontend-request-%d{yyyy-MM-dd_HH}.log</fileNamePattern>
			<!-- keep 30 days' worth of history -->
			<maxHistory>30</maxHistory>
		</rollingPolicy>
		<encoder>
			<pattern>%date{HH:mm:ss.SSS} [%thread] %-10level [%file:%line] - %msg - %logger %date{dd:MM:yyyy}%n</pattern>
		</encoder>
	</appender>

	<logger name="com.echovox" additivity="false" level="DEBUG">
		<appender-ref ref="RF" />
	</logger>

	<logger name="HttpRequest" additivity="false" level="INFO">
		<appender-ref ref="HttpRequest" />
	</logger>

	<logger name="org.springframework" additivity="false" level="ERROR">
		<appender-ref ref="RF" />
	</logger>

	<root level="ERROR">
		<appender-ref ref="RF" />
	</root>
</configuration>